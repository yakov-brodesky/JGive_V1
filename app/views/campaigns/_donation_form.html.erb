<section class="donation-panel" aria-label="טופס תרומה" data-controller="donation-form">
  <div class="donation-panel__head">
    <span>תשלום מאובטח</span>
    <strong>פרטי התרומה שלי</strong>
  </div>

<%= form_with model: [ campaign, donation ], class: "donation-form", data: { donation_form_target: "form" } do |form| %>
  <% if donation.errors.any? %>
    <div class="flash flash--error">
      <p>לא ניתן לשמור את התרומה:</p>
      <ul>
        <% donation.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="donation-form__body">
    <fieldset class="segmented-control">
      <legend>סוג התרומה</legend>
      <%= form.radio_button :recurrence, "one_time", checked: donation.recurrence.blank? || donation.one_time? || !campaign.allows_recurring?, id: "donation_recurrence_one_time" %>
      <%= form.label :recurrence_one_time, "תרומה חד-פעמית", for: "donation_recurrence_one_time" %>

      <%= form.radio_button :recurrence, "monthly", checked: campaign.allows_recurring? && donation.monthly?, id: "donation_recurrence_monthly", disabled: !campaign.allows_recurring? %>
      <%= form.label :recurrence_monthly, for: "donation_recurrence_monthly" do %>
        הוראת קבע
        <% unless campaign.allows_recurring? %>
          <small class="segmented-control__hint">בקרוב</small>
        <% end %>
      <% end %>
    </fieldset>

    <% donation_options = campaign.donation_options.active.ordered.to_a %>
    <% default_option = donation_options.find { |option| option.badge.present? } || donation_options[2] %>

    <% if donation_options.any? %>
      <fieldset class="amount-grid">
        <legend>בחרו סכום</legend>
        <% donation_options.each do |option| %>
          <% field_id = "donation_option_#{option.id}" %>
          <% checked = donation.donation_option_id == option.id || (donation.donation_option_id.blank? && donation.amount_cents.blank? && option == default_option) %>
          <div class="amount-option">
            <%= form.radio_button :donation_option_id, option.id, checked: checked, id: field_id, data: { donation_form_target: "amountRadio", amount_cents: option.amount_cents, action: "change->donation-form#updateTotal" } %>
            <%= form.label :donation_option_id, for: field_id do %>
              <strong><%= format_ils(option.amount_cents) %></strong>
              <span><%= option.label %></span>
              <% if option.badge.present? %>
                <em><%= option.badge %></em>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </fieldset>
    <% end %>

    <div class="field field--custom-amount">
      <%= label_tag "donation_custom_amount", "סכום אחר" %>
      <%= number_field_tag "donation[custom_amount]",
            nil,
            id: "donation_custom_amount",
            min: 1,
            step: 1,
            placeholder: "סכום בשקלים",
            data: { donation_form_target: "customAmount", action: "input->donation-form#updateTotal" } %>
    </div>

    <div class="form-toggle-row">
      <%= check_box_tag "donation[add_note]", "1", donation.note.present?, id: "donation_add_note", data: { donation_form_target: "noteCheckbox", action: "change->donation-form#toggleNote" } %>
      <%= label_tag "donation_add_note", "רוצה להוסיף הערה?" %>
    </div>

    <div class="field field--note" data-donation-form-target="notePanel" hidden>
      <%= form.label :note, "הערה לקמפיין" %>
      <%= form.text_area :note, rows: 3, placeholder: "הערה זאת תוצג בקמפיין..." %>
    </div>

    <div class="form-toggle-row form-toggle-row--switch">
      <%= check_box_tag "donation[dedication_enabled]", "1", donation.dedicated?, id: "donation_dedication_enabled", class: "toggle-switch__input", data: { donation_form_target: "dedicationToggle", action: "change->donation-form#toggleDedication" } %>
      <label class="form-toggle-row__label" for="donation_dedication_enabled">הקדשת תרומה</label>
      <label class="toggle-switch" for="donation_dedication_enabled" aria-hidden="true">
        <span class="toggle-switch__visual"></span>
      </label>
    </div>

    <div class="dedication-panel" data-donation-form-target="dedicationPanel" hidden>
      <fieldset class="dedication-type">
        <legend>סוג ההקדשה: <span class="required">*</span></legend>
        <%= form.radio_button :dedication_type, "honor", checked: donation.dedication_type.blank? || donation.honor?, id: "donation_dedication_type_honor", data: { action: "change->donation-form#updateDedicationType" } %>
        <%= form.label :dedication_type_honor, "לכבוד", for: "donation_dedication_type_honor" %>

        <%= form.radio_button :dedication_type, "memory", id: "donation_dedication_type_memory", data: { donation_form_target: "memoryRadio", action: "change->donation-form#updateDedicationType" } %>
        <%= form.label :dedication_type_memory, "לזכר", for: "donation_dedication_type_memory" %>
      </fieldset>

      <div class="field">
        <%= form.label :dedication_honoree, nil, data: { donation_form_target: "honoreeLabel" } do %>
          <%= donation.memory? ? "לזכר מי ההקדשה" : "לכבוד מי ההקדשה" %> <span class="required">*</span>
        <% end %>
        <%= form.text_field :dedication_honoree, placeholder: donation.memory? ? "לזכר מי ההקדשה" : "לכבוד מי ההקדשה", data: { donation_form_target: "honoreeField" } %>
      </div>

      <div class="field" data-donation-form-target="recipientNamePanel" hidden>
        <%= form.label :dedication_recipient_name, "למי תשלח ההקדשה" %>
        <%= form.text_field :dedication_recipient_name, placeholder: "למי תשלח ההקדשה" %>
      </div>

      <div class="field">
        <%= form.label :dedication_recipient_email, "אימייל לשליחה" %>
        <span class="required">*</span>
        <%= form.email_field :dedication_recipient_email, placeholder: "you@example.com" %>
      </div>

      <div class="field">
        <%= form.label :dedication_message, "הודעה אישית" %>
        <%= form.text_area :dedication_message, rows: 3, placeholder: "הודעה אישית" %>
      </div>
    </div>

    <div class="field">
      <%= form.label :display_preference, "אני רוצה שבעמוד הפרויקט יופיע:" %>
      <%= form.select :display_preference, display_preference_options, {} %>
    </div>

    <div class="field">
      <%= form.label :donor_email, "אימייל לקבלת אישור" %>
      <%= form.email_field :donor_email, required: true, placeholder: "you@example.com" %>
    </div>

    <div class="field">
      <%= form.label :donor_name, "שם מלא" %>
      <%= form.text_field :donor_name, placeholder: "השם שלך" %>
      <small class="field__hint">לא נדרש בתרומה אנונימית.</small>
    </div>
  </div>

  <div class="donation-form__footer">
    <div class="donation-panel__total">
      <span>סכום התרומה שלך</span>
      <strong data-donation-form-target="totalAmount">ייבחר בטופס</strong>
    </div>

    <%= form.submit "המשך", class: "btn btn--primary btn--donate" %>
  </div>
<% end %>
</section>
